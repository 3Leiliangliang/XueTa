APP_NAME=XueTa Backend
APP_ENV=development
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
PROJECT_DESCRIPTION=AI learning assistant backend powered by FastAPI, PostgreSQL and pgvector.
SECRET_KEY=replace-me-with-a-strong-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/xueta
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
RUN_MIGRATIONS_ON_STARTUP=true
AUTO_CREATE_TABLES=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus
OPENAI_EMBEDDING_MODEL=text-embedding-v4
OPENAI_TIMEOUT_SECONDS=20
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LOCAL_STORAGE_PATH=storage
